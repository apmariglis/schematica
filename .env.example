# ── API Keys ────────────────────────────────────────────────────────────────────
# Provide the key for whichever provider SC_MODEL uses.
# Anthropic:  https://console.anthropic.com/settings/keys
# Google:     https://aistudio.google.com/apikey

ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# MISTRAL_API_KEY=...


# ── Output ───────────────────────────────────────────────────────────────────────
# Base directory for all catalogue and overview output files.
# Structure: <SC_OUTPUT_DIR>/<model>/<db_stem>_catalogue_<n>.json
# Override for a specific run: --out path/to/output/dir

SC_OUTPUT_DIR=data


# ── Model ────────────────────────────────────────────────────────────────────────
# Use the provider prefix that matches your API key above.
#
#   anthropic/claude-haiku-4-5      fast, cheap
#   anthropic/claude-sonnet-4-6     balanced
#   gemini/gemini-2.5-flash         fast, cheap (default)
#   gemini/gemini-2.5-pro           more capable
#
# Override for a single run without editing this file: --model <model>

SC_MODEL=gemini/gemini-2.5-flash

# Prompt caching — Anthropic models only (true/false).
# Cuts cost significantly on repeated runs against the same schema.
# Override for a single run: --cache

SC_CACHE=false


# ── Query limits ─────────────────────────────────────────────────────────────────
# Controls how much data the agent sees per query during exploration.
# Increase if the agent misses patterns in wide or irregular datasets.

SC_MAX_ROWS=5
SC_MAX_CHARS=500


# ── Exploration budget (Phase 1) ─────────────────────────────────────────────────
# How many LLM iterations the agent gets to explore before it must produce output.
# Budget scales with database size: min(BASE + n_tables × MULTIPLIER, CAP)
#
#   n_tables=5  → min(10 + 5×3,  50) = 25 iterations
#   n_tables=14 → min(10 + 14×3, 50) = 50 iterations  (capped)

SC_BUDGET_BASE=10
SC_BUDGET_MULTIPLIER=3
SC_BUDGET_CAP=50

# Minimum iterations before finish_catalogue is accepted.
# Computed as: max(FLOOR, budget ÷ DIVISOR)
# With defaults (FLOOR=10, DIVISOR=2) the agent must use at least half its budget.

SC_MIN_ITER_FLOOR=10
SC_MIN_ITER_DIVISOR=2


# ── Refinement budget (Phase 3) ──────────────────────────────────────────────────
# Max LLM iterations for the validation/fix loop after the catalogue is drafted.
# Increase if you have many tables with complex SQL issues.

SC_REFINEMENT_BUDGET=15


# ── LLM call limits ──────────────────────────────────────────────────────────────
# Max output tokens per API call.
# Must not exceed the model's own output token limit:
#   anthropic/claude-haiku-4-5   →  8,192
#   gemini/gemini-2.5-flash      → 65,536

SC_MAX_OUTPUT_TOKENS=32768

# Maximum number of run_query calls executed per iteration turn.
# Keeping this low reduces the number of results the model must synthesise
# in one turn, which lowers the risk of empty responses on thinking-heavy models.
# Queries beyond the cap receive a "deferred" result and the model resubmits them
# in the next turn. Set to 0 to disable the cap (no limit).
SC_MAX_QUERIES_PER_TURN=3

# Number of independent Phase-1 exploration runs before a single Phase-2
# documentation pass.  When > 1, each run explores and validates SQL
# independently; all query results are combined into one context for Phase-2
# so the documentation agent sees the full evidence from every run.
# This reduces variance in metric selection at the cost of proportionally
# more tokens (N × Phase-1 cost + one Phase-2 cost).
# Set to 1 to disable ensemble mode and use the original single-run behaviour.
SC_ENSEMBLE_RUNS=3
