# LLM model (supports anthropic/, gemini/ prefixes via LiteLLM)
# Use a plain model ID for Anthropic native SDK (e.g. claude-sonnet-4-20250514)
SC_MODEL=gemini/gemini-2.5-flash

# Prompt caching — Anthropic native SDK only
SC_CACHE=false

# Query result truncation (prevents large outputs filling the context window)
SC_MAX_ROWS=5
SC_MAX_CHARS=500

# Phase 1 exploration budget: min(BASE + n_tables × MULTIPLIER, CAP)
SC_BUDGET_BASE=10
SC_BUDGET_MULTIPLIER=3
SC_BUDGET_CAP=50

# Minimum iterations before finish_catalogue is accepted
SC_MIN_ITER_FLOOR=10
SC_MIN_ITER_DIVISOR=2

# Phase 3 refinement budget
SC_REFINEMENT_BUDGET=15

# Max output tokens per LLM call
SC_MAX_OUTPUT_TOKENS=32768

# API keys — provide whichever provider your SC_MODEL uses
ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...       # required for gemini/ models
